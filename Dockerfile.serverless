FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

WORKDIR /app

# Uninstall conflicting flash-attention first, then install compatible versions
RUN pip uninstall -y flash-attn flash_attn 2>/dev/null; \
    pip install --no-cache-dir \
    runpod>=1.7.0 \
    "diffusers>=0.33.0" \
    "transformers>=4.48.0" \
    accelerate>=1.0.0 \
    safetensors>=0.4.0 \
    gguf>=0.10.0 \
    sentencepiece \
    protobuf \
    ftfy \
    imageio[ffmpeg] \
    imageio-ffmpeg \
    huggingface_hub \
    Pillow \
    numpy

# Remove flash-attn AFTER install (conflicts with diffusers autoencoder_kl_wan)
RUN pip uninstall -y flash-attn flash_attn 2>/dev/null; true

# No models baked in - downloaded on first start to /tmp/models
RUN mkdir -p /tmp/models

# Copy handler
COPY handler.py /app/handler.py

ENV PYTHONUNBUFFERED=1

CMD ["python", "-u", "/app/handler.py"]
